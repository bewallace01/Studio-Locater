# Create a project at https://www.sanity.io/ — then Project ID → here
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Maps / Places (Studio map picker; enable Maps JavaScript API + Places API; restrict key by HTTP referrer)
SANITY_STUDIO_GOOGLE_MAPS_API_KEY=

# --- Sanity write access (import, enrich scripts, Cloudflare Worker secrets) ---
# https://www.sanity.io/manage → API → Tokens (Editor or Admin)
SANITY_API_TOKEN=

# --- Google Places (local enrich script; usually same as SANITY_STUDIO_GOOGLE_MAPS_API_KEY) ---
GOOGLE_API_KEY=

# --- OpenAI (enrich script + enrich Worker) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Enrich Worker manual /run (optional locally) ---
CRON_SECRET=
