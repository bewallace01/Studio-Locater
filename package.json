{
  "name": "studio-locater",
  "version": "1.0.0",
  "private": true,
  "description": "Studio Locater — Sanity + optional Yelp discovery",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "node -e \"require('fs').accessSync('public/index.html'); console.log('OK: public/index.html')\"",
    "deploy": "npx wrangler deploy --env staging",
    "deploy:api": "npx wrangler deploy -c wrangler.api-search.toml --env staging",
    "deploy:enrich": "npx wrangler deploy -c wrangler.enrich.toml --env staging",
    "deploy:all": "npm run deploy && npm run deploy:api && npm run deploy:enrich",
    "deploy:prod": "npx wrangler deploy",
    "deploy:api:prod": "npx wrangler deploy -c wrangler.api-search.toml",
    "deploy:enrich:prod": "npx wrangler deploy -c wrangler.enrich.toml",
    "deploy:all:prod": "npm run deploy:prod && npm run deploy:api:prod && npm run deploy:enrich:prod",
    "deploy:staging": "npm run deploy",
    "deploy:api:staging": "npm run deploy:api",
    "deploy:enrich:staging": "npm run deploy:enrich",
    "deploy:all:staging": "npm run deploy:all",
    "dev:worker": "npx wrangler dev",
    "d1:migrate:local": "npx wrangler d1 execute studio-locater-admin --file=migrations/001_admin.sql --local -y",
    "d1:migrate:local:signups": "npx wrangler d1 execute studio-locater-admin --file=migrations/002_signups_contact.sql --local -y",
    "d1:migrate:remote": "npx wrangler d1 execute studio-locater-admin --file=migrations/001_admin.sql --remote -y",
    "d1:migrate:remote:signups": "npx wrangler d1 execute studio-locater-admin --file=migrations/002_signups_contact.sql --remote -y",
    "d1:migrate:local:accounts": "npx wrangler d1 execute studio-locater-admin --file=migrations/003_accounts.sql --local -y",
    "d1:migrate:remote:accounts": "npx wrangler d1 execute studio-locater-admin --file=migrations/003_accounts.sql --remote -y",
    "d1:migrate:local:signup-email": "npx wrangler d1 execute studio-locater-admin --file=migrations/004_signup_unique_email.sql --local -y",
    "d1:migrate:remote:signup-email": "npx wrangler d1 execute studio-locater-admin --file=migrations/004_signup_unique_email.sql --remote -y",
    "d1:migrate:local:blog-notify": "npx wrangler d1 execute studio-locater-admin --file=migrations/005_blog_subscriber_notify_sent.sql --local -y",
    "d1:migrate:remote:blog-notify": "npx wrangler d1 execute studio-locater-admin --file=migrations/005_blog_subscriber_notify_sent.sql --remote -y",
    "d1:migrate:local:reviews": "npx wrangler d1 execute studio-locater-admin --file=migrations/006_studio_reviews.sql --local -y",
    "d1:migrate:remote:reviews": "npx wrangler d1 execute studio-locater-admin --file=migrations/006_studio_reviews.sql --remote -y",
    "d1:migrate:local:reviews-name": "npx wrangler d1 execute studio-locater-admin --file=migrations/007_studio_reviews_name.sql --local -y",
    "d1:migrate:remote:reviews-name": "npx wrangler d1 execute studio-locater-admin --file=migrations/007_studio_reviews_name.sql --remote -y",
    "cms": "npm run dev --prefix studio",
    "cms:deploy": "node scripts/sanity-deploy.mjs",
    "import:search": "node scripts/import-from-search-api.mjs",
    "enrich:studios": "node scripts/enrich-studios-from-reviews.mjs",
    "backfill:slugs": "node scripts/backfill-studio-slugs.mjs",
    "mindbody:sandbox": "node scripts/mindbody-sandbox-test.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sanity/client": "^6.24.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  }
}
