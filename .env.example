# Map app port (default 3040 in server.js). Use 3000 only if nothing else is on it.
PORT=3040

# Yelp Fusion — live search only; do not bulk-sync into Sanity (see docs/api-compliance.md)
# Create an app: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# --- Sanity Studio (see studio/.env.example) ---
# The site reads the public project id from <meta name="sanity-project-id"> in public/index.html
# Root-level Node scripts (e.g. scripts/*.mjs) use SANITY_API_TOKEN from studio/.env or this file — never commit tokens.
